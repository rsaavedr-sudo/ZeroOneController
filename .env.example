# ---------------------------------------------------------------------------
# Variáveis de ambiente (Vite). Copie para `.env.local` e ajuste os valores.
# Apenas variáveis com prefixo VITE_ ficam disponíveis no frontend.
# ---------------------------------------------------------------------------

# Usar dados mock (true) ou consumir a API real (false).
# Enquanto o backend não estiver pronto, mantenha true.
VITE_USE_MOCK=true

# URL base da API real (usada quando VITE_USE_MOCK=false).
# Ex.: https://api.seu-dominio.com  ou  /api
VITE_API_BASE_URL=/api

# Token de autenticação para desenvolvimento (opcional).
# Em produção, prefira fluxo de login/refresh em vez de token fixo.
# VITE_API_TOKEN=
